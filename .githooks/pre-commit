#!/usr/bin/env bash

# Auto-format staged files with Prettier before committing.
# Only formats files that are actually staged (not the whole project).

cd "$(git rev-parse --show-toplevel)/frontend" || exit 1

# Get staged files relative to repo root, keep only frontend/ files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d | grep '^frontend/' | sed 's|^frontend/||')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Run Prettier on staged files only
echo "$STAGED_FILES" | xargs bun x prettier --write --ignore-unknown 2>/dev/null

# Re-stage formatted files (paths are relative to frontend/, which is cwd)
echo "$STAGED_FILES" | xargs git add

exit 0
