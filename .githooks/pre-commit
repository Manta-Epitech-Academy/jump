#!/usr/bin/env bash

# Auto-format staged files with Prettier before committing.
#
# Formats the staged blob (what git will commit), not the worktree file, so
# partial staging (git add -p) is preserved: only the staged hunks get
# formatted, unstaged hunks stay untouched. The worktree is then synced as
# a best-effort second step to avoid "status dirty" after commit.

set -e
cd "$(git rev-parse --show-toplevel)"

STAGED=$(git diff --cached --name-only --diff-filter=d | grep '^frontend/') || true
if [ -z "$STAGED" ]; then
  exit 0
fi

# 1. Format the staged blobs in the index (leaves worktree untouched).
while IFS= read -r file; do
  mode=$(git ls-files --stage -- "$file" | awk '{print $1}')
  rel="${file#frontend/}"
  tmp=$(mktemp)
  git show ":$file" | (cd frontend && bun x prettier --stdin-filepath "$rel" --ignore-unknown) > "$tmp" || true
  # Skip if Prettier couldn't parse it (--ignore-unknown emits empty stdout for
  # unsupported extensions like .prisma/.sql, which would otherwise overwrite
  # the index with an empty blob).
  if [ -s "$tmp" ]; then
    hash=$(git hash-object -w -- "$tmp")
    git update-index --cacheinfo "$mode,$hash,$file"
  fi
  rm -f "$tmp"
done <<< "$STAGED"

# 2. Sync the worktree to match. Best-effort: don't block commit on failure.
echo "$STAGED" | sed 's|^frontend/||' | (cd frontend && xargs bun x prettier --write --ignore-unknown) 2>/dev/null || true

exit 0
