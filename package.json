{
	"name": "codecamp-manager",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"db:setup": "bun setup-pocketbase.ts",
		"db:start": "cd pocketbase-backend && ./pocketbase serve",
		"typegen": "pocketbase-typegen --db ./pocketbase-backend/pb_data/data.db --out ./src/lib/pocketbase-types.ts",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"devDependencies": {
		"@internationalized/date": "^3.10.1",
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"bits-ui": "^2.15.5",
		"clsx": "^2.1.1",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"pocketbase-typegen": "^1.3.3",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.49.1",
		"svelte-check": "^4.3.6",
		"svelte-sonner": "^1.0.7",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@fontsource-variable/ibm-plex-sans": "^5.2.8",
		"@fontsource/anton": "^5.2.7",
		"@types/bun": "^1.3.8",
		"@types/canvas-confetti": "^1.9.0",
		"@types/node": "^25.1.0",
		"@types/papaparse": "^5.5.2",
		"canvas-confetti": "^1.9.4",
		"html2canvas": "^1.4.1",
		"jspdf": "^4.0.0",
		"lucide-svelte": "^0.562.0",
		"papaparse": "^5.5.3",
		"pocketbase": "^0.26.8",
		"sveltekit-superforms": "^2.29.1",
		"zod": "^4.3.6"
	}
}
