{
  "name": "tekcamp",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "db:setup": "bun ../setup-pocketbase.ts",
    "db:start": "cd ../pocketbase-backend && ./pocketbase serve",
    "typegen": "pocketbase-typegen --db ../pocketbase-backend/pb_data/data.db --out ./src/lib/pocketbase-types.ts",
    "dev": "bun --env-file=../.env vite dev",
    "build": "bun --env-file=../.env vite build",
    "preview": "bun --env-file=../.env vite preview",
    "start": "bun --env-file=../.env ./build/index.js",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^0.561.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/ejs": "^3.1.5",
    "bits-ui": "^2.16.4",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "pocketbase-typegen": "^1.3.3",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.55.0",
    "svelte-check": "^4.4.5",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/anton": "^5.2.7",
    "@types/bun": "^1.3.11",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "canvas-confetti": "^1.9.4",
    "ejs": "^4.0.1",
    "marked": "^17.0.5",
    "papaparse": "^5.5.3",
    "pocketbase": "^0.26.8",
    "puppeteer": "^24.40.0",
    "sveltekit-superforms": "^2.30.1",
    "zod": "^4.3.6"
  }
}
