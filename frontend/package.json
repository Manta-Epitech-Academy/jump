{
  "name": "jump",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "garage:generate": "bun run scripts/configure-garage.ts",
    "dev": "bun --bun --env-file=../.env vite dev",
    "build": "bun --bun --env-file=../.env vite build",
    "preview": "bun --bun --env-file=../.env vite preview",
    "start": "bun --env-file=../.env ./build/index.js",
    "prepare": "cd .. && git config core.hooksPath .githooks || true && cd frontend && svelte-kit sync || echo ''",
    "postinstall": "prisma generate",
    "check": "KIT_OUTDIR=.svelte-kit-check svelte-kit sync && KIT_OUTDIR=.svelte-kit-check svelte-check --tsconfig ./tsconfig.check.json",
    "check:watch": "KIT_OUTDIR=.svelte-kit-check svelte-kit sync && KIT_OUTDIR=.svelte-kit-check svelte-check --tsconfig ./tsconfig.check.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^0.561.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/ejs": "^3.1.5",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.8.0",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/anton": "^5.2.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "^1.3.13",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "better-auth": "^1.6.7",
    "brace-expansion": "^5.0.5",
    "canvas-confetti": "^1.9.4",
    "ejs": "^4.0.1",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.6",
    "marked-highlight": "^2.2.4",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "postcss": "^8.5.10",
    "puppeteer": "^24.42.0",
    "resend": "^6.12.2",
    "sveltekit-superforms": "^2.30.1",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  },
  "overrides": {
    "basic-ftp": "^5.2.1",
    "picomatch": "^4.0.4",
    "cookie": "^0.7.0",
    "@hono/node-server": "^1.19.13",
    "hono": "^4.12.14",
    "brace-expansion": "^5.0.5",
    "fast-xml-parser": "^5.7.0",
    "uuid": "^14.0.0",
    "postcss": "^8.5.10"
  }
}
