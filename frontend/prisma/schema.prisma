generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───

// Difficulty stored as plain string: "Débutant", "Intermédiaire", "Avancé"
// This avoids enum mapping issues between Prisma TS names and French display values.

// StudentLevel stored as plain string: "Novice", "Apprentice", "Expert"
// Niveau stored as plain string: "6eme", "5eme", "4eme", "3eme", "2nde", "1ere", "Terminale", "Sup"

enum StepStatus {
  active
  needs_help
  completed
}

enum UnlockSource {
  student
  staff
}

enum ActivityType {
  atelier
  conference
  quiz
  orga
  special
  break
}

enum StaffRole {
  admin
  superdev
  dev
  peda
  manta
}

enum InterviewStatus {
  planned
  completed
  cancelled
}

// ─── Auth (BetterAuth managed) ───

model bauth_user {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  role          String    @default("user")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions          bauth_session[]
  accounts          bauth_account[]
  staffProfile      StaffProfile?
  talent            Talent?
  invitationsIssued StaffInvitation[] @relation("StaffInvitationInvitedBy")
}

model bauth_session {
  id             String   @id @default(cuid())
  userId         String
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  impersonatedBy String?

  user bauth_user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model bauth_account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user bauth_user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model bauth_verification {
  id         String   @id @default(cuid())
  identifier String   @unique
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Domain Profiles ───

model StaffProfile {
  id        String     @id @default(cuid())
  userId    String     @unique
  campusId  String?
  staffRole StaffRole?
  avatar    String?
  discordId String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user                bauth_user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campus              Campus?         @relation(fields: [campusId], references: [id])
  eventMantas         EventManta[]
  notesAuthored       Participation[] @relation("NoteAuthor")
  interviewsConducted Interview[]
  adminFiles          AdminFile[]
  subjectVersionsImported SubjectVersion[]
  observableValidations   TalentObservableState[]

  @@index([campusId])
}

model StaffInvitation {
  id              String    @id @default(cuid())
  email           String    @unique
  campusId        String?
  staffRole       StaffRole
  invitedByUserId String
  createdAt       DateTime  @default(now())

  campus    Campus?    @relation(fields: [campusId], references: [id], onDelete: Cascade)
  invitedBy bauth_user @relation("StaffInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([campusId])
}

model Talent {
  id                String    @id @default(cuid())
  userId            String?   @unique
  email             String?   @unique
  nom               String
  prenom            String
  niveau            String?
  niveauDifficulte  String?
  level             String    @default("Novice")
  xp                Int       @default(0)
  eventsCount       Int       @default(0)
  charterAcceptedAt     DateTime?
  rulesSignedAt         DateTime?
  imageRightsSignedAt   DateTime?
  imageRightsSignerName String?
  infoValidatedAt       DateTime?
  charterFilePath       String?
  rulesFilePath         String?
  imageRightsFilePath   String?
  badges                Json?
  parentEmail       String?
  parentNom         String?
  parentPrenom      String?
  parentPhone       String?
  phone             String?
  discordId         String?   @unique
  externalId        String?   @unique
  lastSyncedAt      DateTime?
  lastActiveAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user           bauth_user?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  participations Participation[]
  stepsProgress  StepsProgress[]
  portfolioItems PortfolioItem[]
  interviews     Interview[]
  observableStates TalentObservableState[]
  competenceStates TalentCompetenceState[]
  quizAttempts     TalentQuizAttempt[]
}

// ─── Domain Tables ───

model Campus {
  id           String   @id @default(cuid())
  name         String   @unique
  externalName String?  @unique
  timezone     String   @default("Europe/Paris")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  staffProfiles     StaffProfile[]
  events            Event[]
  themes            Theme[]
  participations    Participation[]
  activityTemplates ActivityTemplate[]
  interviews        Interview[]
  invitations       StaffInvitation[]
  featureFlags      CampusFeatureFlag[]
}

model Theme {
  id        String   @id @default(cuid())
  nom       String
  campusId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campus                 Campus?                 @relation(fields: [campusId], references: [id])
  events                 Event[]
  activityTemplateThemes ActivityTemplateTheme[]
  activityThemes         ActivityTheme[]

  @@unique([nom, campusId])
}

model ActivityTemplate {
  id               String       @id @default(cuid())
  nom              String
  description      String?
  difficulte       String?
  activityType     ActivityType
  isDynamic        Boolean      @default(false)
  campusId         String?
  link             String?
  content          String?
  contentStructure Json?
  defaultDuration  Int?
  subjectId        String?
  subjectVersionId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  campus                 Campus?                @relation(fields: [campusId], references: [id])
  activityTemplateThemes ActivityTemplateTheme[]
  planningTemplateSlots  PlanningTemplateSlot[]
  subject                Subject?               @relation(fields: [subjectId], references: [id])
  subjectVersion         SubjectVersion?        @relation(fields: [subjectVersionId], references: [id])

  @@index([subjectId])
  @@index([subjectVersionId])
}

model ActivityTemplateTheme {
  activityTemplateId String
  themeId            String

  activityTemplate ActivityTemplate @relation(fields: [activityTemplateId], references: [id], onDelete: Cascade)
  theme            Theme            @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([activityTemplateId, themeId])
}

model Planning {
  id        String   @id @default(cuid())
  eventId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  timeSlots TimeSlot[]
}

model TimeSlot {
  id         String   @id @default(cuid())
  planningId String
  startTime  DateTime
  endTime    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  planning Planning  @relation(fields: [planningId], references: [id], onDelete: Cascade)
  activity Activity?

  @@index([planningId])
}

model Activity {
  id               String       @id @default(cuid())
  nom              String
  description      String?
  difficulte       String?
  activityType     ActivityType
  isDynamic        Boolean      @default(false)
  link             String?
  content          String?
  contentStructure Json?
  timeSlotId       String       @unique
  templateId       String?
  subjectVersionId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  timeSlot                TimeSlot                @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)
  activityThemes          ActivityTheme[]
  participationActivities ParticipationActivity[]
  stepsProgress           StepsProgress[]
  portfolioItems          PortfolioItem[]
  subjectVersion          SubjectVersion?         @relation(fields: [subjectVersionId], references: [id])

  @@index([templateId])
  @@index([subjectVersionId])
}

model ActivityTheme {
  activityId String
  themeId    String

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  theme    Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([activityId, themeId])
}

model Event {
  id         String    @id @default(cuid())
  titre      String
  date       DateTime
  endDate    DateTime?
  eventType  String    @default("coding_club")
  campusId   String
  themeId    String?
  pin        String?
  notes      String?
  externalId String?   @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  campus         Campus          @relation(fields: [campusId], references: [id])
  theme          Theme?          @relation(fields: [themeId], references: [id])
  mantas         EventManta[]
  participations Participation[]
  stepsProgress  StepsProgress[]
  portfolioItems PortfolioItem[]
  planning       Planning?
  observableStates TalentObservableState[]
  quizAttempts     TalentQuizAttempt[]

  @@index([campusId])
}

model EventManta {
  eventId        String
  staffProfileId String

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  staffProfile StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@id([eventId, staffProfileId])
}

model Participation {
  id        String  @id @default(cuid())
  talentId  String
  eventId   String
  campusId  String
  isPresent Boolean @default(false)
  delay     Int?    @default(0)
  bringPc   Boolean @default(false)

  note           String?
  noteAuthorId   String?
  camperRating   Int?
  camperFeedback String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  talent          Talent                  @relation(fields: [talentId], references: [id], onDelete: Cascade)
  event           Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  campus          Campus                  @relation(fields: [campusId], references: [id])
  noteAuthor      StaffProfile?           @relation("NoteAuthor", fields: [noteAuthorId], references: [id])
  activities      ParticipationActivity[]
  stageCompliance StageCompliance?
  interview       Interview?

  @@unique([talentId, eventId])
  @@index([eventId])
  @@index([campusId])
  @@index([talentId])
  @@index([talentId, campusId])
}

model StageCompliance {
  participationId   String   @id
  charteSigned      Boolean  @default(false)
  conventionSigned  Boolean  @default(false)
  imageRightsSigned Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  participation Participation @relation(fields: [participationId], references: [id], onDelete: Cascade)
}

model ParticipationActivity {
  participationId String
  activityId      String
  isPresent       Boolean @default(false)
  delay           Int     @default(0)

  participation Participation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  activity      Activity      @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@id([participationId, activityId])
}

model Interview {
  id              String          @id @default(cuid())
  talentId        String
  staffId         String
  campusId        String
  participationId String?         @unique
  date            DateTime
  status          InterviewStatus @default(planned)

  discoveryReason   String?
  motivation        String?
  nextEventInterest String?
  influencers       String?
  platforms         String?
  specialties       String?
  interests         String?
  otherJobs         String?
  satisfaction      String?
  globalNote        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  talent        Talent         @relation(fields: [talentId], references: [id], onDelete: Cascade)
  staff         StaffProfile   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  campus        Campus         @relation(fields: [campusId], references: [id], onDelete: Cascade)
  participation Participation? @relation(fields: [participationId], references: [id], onDelete: SetNull)

  @@index([talentId])
  @@index([staffId])
  @@index([campusId])
}

model StepsProgress {
  id               String        @id @default(cuid())
  talentId         String
  eventId          String
  activityId       String?
  currentStepId    String?
  unlockedStepId   String?
  status           StepStatus    @default(active)
  lastUnlockSource UnlockSource?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  talent   Talent    @relation(fields: [talentId], references: [id], onDelete: Cascade)
  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  activity Activity? @relation(fields: [activityId], references: [id])

  @@unique([talentId, activityId])
  @@index([eventId])
  @@index([talentId])
  @@index([activityId])
}

model PortfolioItem {
  id         String   @id @default(cuid())
  talentId   String
  eventId    String
  activityId String?
  file       String?
  url        String?
  caption    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  talent   Talent    @relation(fields: [talentId], references: [id], onDelete: Cascade)
  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  activity Activity? @relation(fields: [activityId], references: [id])

  @@index([talentId])
  @@index([eventId])
}

// ── Sync Error Logging ──

model SyncError {
  id              String    @id @default(cuid())
  errorType       String
  email           String
  attemptedExtId  String
  existingExtId   String?
  talentName      String
  eventExtId      String?
  message         String
  resolved        Boolean   @default(false)
  resolvedAt      DateTime?
  occurrenceCount Int       @default(1)
  lastOccurredAt  DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([email, attemptedExtId])
  @@index([resolved])
  @@index([lastOccurredAt])
}

// ── Planning Templates ──

model PlanningTemplate {
  id          String   @id @default(cuid())
  nom         String   @unique
  description String?
  nbDays      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  days PlanningTemplateDay[]
}

model PlanningTemplateDay {
  id                 String   @id @default(cuid())
  planningTemplateId String
  dayIndex           Int
  label              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  planningTemplate PlanningTemplate       @relation(fields: [planningTemplateId], references: [id], onDelete: Cascade)
  slots            PlanningTemplateSlot[]

  @@unique([planningTemplateId, dayIndex])
  @@index([planningTemplateId])
}

model PlanningTemplateSlot {
  id                    String       @id @default(cuid())
  planningTemplateDayId String
  startTime             String
  endTime               String
  sortOrder             Int          @default(0)
  activityTemplateId    String?
  nom                   String?
  description           String?
  activityType          ActivityType @default(orga)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  day              PlanningTemplateDay @relation(fields: [planningTemplateDayId], references: [id], onDelete: Cascade)
  activityTemplate ActivityTemplate?   @relation(fields: [activityTemplateId], references: [id], onDelete: SetNull)

  @@index([planningTemplateDayId])
  @@index([activityTemplateId])
}

model CampusFeatureFlag {
  campusId  String
  flagKey   String
  enabled   Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campus Campus @relation(fields: [campusId], references: [id], onDelete: Cascade)

  @@id([campusId, flagKey])
  @@index([flagKey])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AdminFile {
  id           String   @id @default(cuid())
  name         String
  s3Key        String   @unique
  contentType  String
  size         Int
  uploadedById String
  createdAt    DateTime @default(now())

  uploadedBy StaffProfile @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([uploadedById])
}

// ─── GitHub-backed Subjects + Competence Reference ───

model RefCompSnapshot {
  id        String   @id @default(cuid())
  commitSha String   @unique
  fetchedAt DateTime @default(now())
  isCurrent Boolean  @default(false)

  competences     Competence[]
  skills          Skill[]
  skillLevels     SkillLevel[]
  observables     Observable[]
  subjectVersions SubjectVersion[]

  @@index([isCurrent])
}

model Competence {
  id         String @id @default(cuid())
  snapshotId String
  domain     String
  desc       String

  snapshot RefCompSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  skills   Skill[]

  @@unique([snapshotId, domain])
}

model Skill {
  id           String @id @default(cuid())
  snapshotId   String
  competenceId String
  numericId    Int
  shortName    String

  snapshot   RefCompSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  competence Competence      @relation(fields: [competenceId], references: [id], onDelete: Cascade)
  levels     SkillLevel[]

  @@unique([snapshotId, competenceId, numericId])
  @@index([snapshotId])
}

model SkillLevel {
  id         String @id @default(cuid())
  snapshotId String
  skillId    String
  level      String
  name       String
  desc       String

  snapshot           RefCompSnapshot         @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  skill              Skill                   @relation(fields: [skillId], references: [id], onDelete: Cascade)
  subjectObservables SubjectObservable[]
  competenceStates   TalentCompetenceState[]

  @@unique([snapshotId, skillId, level])
  @@index([snapshotId])
}

model Observable {
  id          String @id @default(cuid())
  snapshotId  String
  projectSlug String
  externalId  Int
  desc        String

  snapshot           RefCompSnapshot         @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  subjectObservables SubjectObservable[]
  states             TalentObservableState[]

  @@unique([snapshotId, projectSlug, externalId])
  @@index([snapshotId])
  @@index([projectSlug])
}

model Subject {
  id      String @id @default(cuid())
  repoUrl String @unique
  slug    String @unique

  versions  SubjectVersion[]
  templates ActivityTemplate[]
}

model SubjectVersion {
  id                String   @id @default(cuid())
  subjectId         String
  repoCommitSha     String
  refCompSnapshotId String
  metadataJson      Json
  importedAt        DateTime @default(now())
  importedById      String

  subject         Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  refCompSnapshot RefCompSnapshot     @relation(fields: [refCompSnapshotId], references: [id])
  importedBy      StaffProfile        @relation(fields: [importedById], references: [id])
  documents       Document[]
  sections        Section[]
  quizzes         SubjectQuiz[]
  observableLinks SubjectObservable[]
  activities      Activity[]
  templates       ActivityTemplate[]

  @@unique([subjectId, repoCommitSha])
  @@index([subjectId])
  @@index([refCompSnapshotId])
}

model Document {
  id               String @id @default(cuid())
  subjectVersionId String
  path             String
  rawMd            String
  renderedHtml     String
  sortOrder        Int

  subjectVersion SubjectVersion @relation(fields: [subjectVersionId], references: [id], onDelete: Cascade)
  sections       Section[]
  quizzes        SubjectQuiz[]

  @@unique([subjectVersionId, path])
  @@index([subjectVersionId])
}

model Section {
  id               String @id @default(cuid())
  subjectVersionId String
  documentId       String
  level            Int
  anchor           String
  title            String
  sortOrder        Int

  subjectVersion        SubjectVersion          @relation(fields: [subjectVersionId], references: [id], onDelete: Cascade)
  document              Document                @relation(fields: [documentId], references: [id], onDelete: Cascade)
  observableLinks       SubjectObservable[]
  observableStateSource TalentObservableState[] @relation("TalentObservableStateSourceSection")

  @@unique([subjectVersionId, documentId, anchor])
  @@index([subjectVersionId])
  @@index([documentId])
}

model SubjectObservable {
  id               String @id @default(cuid())
  subjectVersionId String
  sectionId        String
  observableId     String
  skillLevelId     String

  subjectVersion SubjectVersion @relation(fields: [subjectVersionId], references: [id], onDelete: Cascade)
  section        Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  observable     Observable     @relation(fields: [observableId], references: [id])
  skillLevel     SkillLevel     @relation(fields: [skillLevelId], references: [id])

  @@unique([sectionId, observableId])
  @@index([subjectVersionId])
  @@index([observableId])
  @@index([skillLevelId])
}

model SubjectQuiz {
  id               String  @id @default(cuid())
  subjectVersionId String
  documentId       String
  fqn              String
  type             String
  expectedCount    Int?
  level            String
  externalIndex    Int
  title            String
  question         String
  options          Json
  canonicalAnswer  Json?

  subjectVersion SubjectVersion      @relation(fields: [subjectVersionId], references: [id], onDelete: Cascade)
  document       Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  attempts       TalentQuizAttempt[]

  @@unique([subjectVersionId, fqn])
  @@index([subjectVersionId])
  @@index([documentId])
}

model TalentObservableState {
  id              String    @id @default(cuid())
  talentId        String
  eventId         String
  observableId    String
  // Section the talent had reached when this row was created. Lets the manta
  // validation view deep-link to the exact spot in the subject without
  // guessing among the SubjectObservable rows linked to the observable.
  sourceSectionId String?
  state           String
  observedById    String?
  observedAt      DateTime?
  createdAt       DateTime  @default(now())

  talent        Talent        @relation(fields: [talentId], references: [id], onDelete: Cascade)
  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  observable    Observable    @relation(fields: [observableId], references: [id])
  observedBy    StaffProfile? @relation(fields: [observedById], references: [id])
  sourceSection Section?      @relation("TalentObservableStateSourceSection", fields: [sourceSectionId], references: [id], onDelete: SetNull)

  @@unique([talentId, eventId, observableId])
  @@index([talentId])
  @@index([eventId])
  @@index([observableId])
  @@index([state])
  @@index([sourceSectionId])
}

model TalentCompetenceState {
  id           String    @id @default(cuid())
  talentId     String
  skillLevelId String
  state        String
  certifiedAt  DateTime?
  updatedAt    DateTime  @updatedAt

  talent     Talent     @relation(fields: [talentId], references: [id], onDelete: Cascade)
  skillLevel SkillLevel @relation(fields: [skillLevelId], references: [id])

  @@unique([talentId, skillLevelId])
  @@index([talentId])
  @@index([skillLevelId])
}

model TalentQuizAttempt {
  id          String   @id @default(cuid())
  talentId    String
  quizId      String
  eventId     String
  submitted   Json
  correct     Boolean
  attemptedAt DateTime @default(now())

  talent Talent      @relation(fields: [talentId], references: [id], onDelete: Cascade)
  quiz   SubjectQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  event  Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([talentId])
  @@index([quizId])
  @@index([eventId])
}
