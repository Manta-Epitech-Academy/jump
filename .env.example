# Database
DATABASE_URL="postgresql://jump:password@localhost:5432/jump"
POSTGRES_PASSWORD=password

# App
PORT=3030
ORIGIN=http://localhost:3030

# BetterAuth
BETTER_AUTH_SECRET=

# Microsoft OAuth (Staff login)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Discord OAuth (Student account linking)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Resend (Student OTP emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Jump <noreply@jump.fr>"

# Security token for background jobs (API /api/jobs/*)
CRON_SECRET=

# Security token for worker API (API /api/worker/*)
WORKER_API_TOKEN=

# Garage S3 Storage
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Garage Admin API (used by bun run db:garage)
GARAGE_ADMIN_ENDPOINT=http://localhost:3903
GARAGE_ADMIN_TOKEN=dev-admin-token
